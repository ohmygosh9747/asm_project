model Employee {
  id              String   @id @default(cuid())
  employeeId      String   @unique
  fullName        String
  nationality     String?
  dateOfBirth     String?
  passportNumber  String?  // encrypted
  idNumber        String?  // encrypted
  phone           String?
  email           String?
  position        String?
  joinDate        String?
  photoUrl        String?
  emergencyContact String?
  address         String?
  status          String   @default("active") // active, inactive, deleted
  createdBy       String?

  // New fields for CV format
  rating          Float    @default(5.0) // 0.0-5.0 stars (auto-calculated)
  companyName     String?  // "Com. Name" in CV
  passportStatus  String?  // Passport Status
  idStatus        String?  // ID Status
  currentSite     String?  // Current working site (references Site name or "idle")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  attendances     Attendance[]
  deleteRequests  DeleteRequest[]
  warnings        Warning[]
  fines           Fine[]
}

model Site {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

model Attendance {
  id             String   @id @default(cuid())
  employeeId     String
  date           String   // DD-MM-YYYY (e.g. 27-04-2026)
  dayName        String?  // e.g. Monday
  status         String   @default("not_marked") // present, absent, no_site, overtime, not_marked
  overtimeHours  Float?   // Hours worked as overtime (only when status = overtime)
  markedBy       String?
  createdAt      DateTime @default(now())

  employee       Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
}

model DeleteRequest {
  id          String   @id @default(cuid())
  employeeId  String
  employeeName String
  requestedBy String
  reason      String?
  status      String   @default("pending") // pending, approved, rejected
  reviewedBy  String?
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model Notification {
  id         String   @id @default(cuid())
  userId     String
  title      String
  message    String
  type       String   @default("info") // info, warning, success, danger
  read       Boolean  @default(false)
  link       String?
  createdAt  DateTime @default(now())
}

model Warning {
  id              String   @id @default(cuid())
